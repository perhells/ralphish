#!/bin/bash
set -e
set -o pipefail

MODE="claude"
WORKSPACE=""
NEW=false
MAX_ITERATIONS=1
INCLUDE_LOCAL_CONFIG=false
CUSTOM_ENV=()
ENV_FILE=""

while [[ $# -gt 0 ]]; do
    case $1 in
    --help)
        usage
        exit 0
        ;;
    --new)
        NEW=true
        shift
        ;;
    --rm)
        MODE="rm"
        shift
        ;;
    --max-iterations)
        shift
        if [ -z "$1" ]; then
          echo "Usage: --max-iterations <iterations>"
          exit 1
        fi
        MAX_ITERATIONS="$1"
        shift
        ;;
    --env=*)
        CUSTOM_ENV+=("${1#--env=}")
        shift
        ;;
    --env)
        if [ -z "$2" ]; then
            echo "Error: --env requires a KEY=VALUE argument"
            exit 1
        fi
        CUSTOM_ENV+=("$2")
        shift 2
        ;;
    --env-file=*)
        ENV_FILE="${1#--env-file=}"
        shift
        ;;
    --env-file)
        if [ -z "$2" ]; then
            echo "Error: --env-file requires a file path argument"
            exit 1
        fi
        ENV_FILE="$2"
        shift 2
        ;;
    --include-local-config)
        INCLUDE_LOCAL_CONFIG=true
        shift
        ;;
    *)
        WORKSPACE="$1"
        shift
        ;;
    esac
done

if [ -z "$WORKSPACE" ]; then
    WORKSPACE="."
fi

if [ -z "$CC_TOKEN" ] && [ "$MODE" != "rm" ]; then
    echo "Error: CC_TOKEN environment variable is not set"
    exit 1
fi

WORKSPACE="$(cd "$WORKSPACE" && pwd)"
BASENAME="$(basename "$WORKSPACE")"

# Truncate sandbox name to avoid Unix socket path length limits
# Docker uses: ~/.docker/sandboxes/vm/<name>/eth (max ~94 chars total)
MAX_NAME_LEN=40
if [ ${#BASENAME} -gt $MAX_NAME_LEN ]; then
    HASH=$(echo -n "$BASENAME" | shasum | cut -c1-6)
    BASENAME="${BASENAME:0:$((MAX_NAME_LEN - 7))}-$HASH"
fi
SANDBOX="claude-$BASENAME"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

case "$MODE" in
rm)
    sandbox --rm "$WORKSPACE"
    ;;
*)
    # Separate init-only args (--new, --include-local-config) from phase args (--env)
    # --new would destroy and recreate the sandbox on every call, breaking inter-phase state
    PHASE_ARGS=()
    for env_var in "${CUSTOM_ENV[@]}"; do PHASE_ARGS+=(--env "$env_var"); done
    [ -n "$ENV_FILE" ] && PHASE_ARGS+=(--env-file "$ENV_FILE")

    INIT_ARGS=("${PHASE_ARGS[@]}")
    [ "$NEW" = true ] && INIT_ARGS+=(--new)
    [ "$INCLUDE_LOCAL_CONFIG" = true ] && INIT_ARGS+=(--include-local-config)

    # Create/resume sandbox (bash exits immediately; 2>/dev/null suppresses TTY warnings)
    sandbox "${INIT_ARGS[@]}" --bash "$WORKSPACE" <<< 'exit 0' 2>/dev/null || true

    # ─── Phase prompts ──────────────────────────────────────────────────

    WORKER_PROMPT='You are the WORKER phase of a three-phase development loop (worker → reviewer → orchestrator).

Current iteration: {{ITERATION}}

## Instructions

1. Check if `.ralphish/context.yaml` exists. If it does, read it for:
   - `assigned_task_id`: work on this specific task
   - `feedback` and `reviewer_remarks`: address this feedback from the previous attempt
   - `prior_attempt_branch` and `prior_attempt_head_sha`: your previous work to build on

2. If no context.yaml exists or it has no assigned_task_id, pick the first eligible task from `progress.yaml`:
   - Status is `todo`
   - All `blocked_by` IDs have status `done`

3. Before creating/switching to a feature branch, record the current HEAD SHA of the base branch — this is your `base_sha`.

4. Implement the task:
   - Create or checkout a feature branch (can be based on default branch or another feature branch)
   - Implement the changes
   - Run all tests/checks and fix any problems
   - Commit your work (one logical change per commit)

5. After committing, record the feature branch HEAD SHA — this is your `head_sha`.

6. Write `.ralphish/summary.yaml` with this exact structure:
   ```yaml
   task_id: <integer>
   task_title: "<string>"
   base_sha: "<40-char sha>"
   head_sha: "<40-char sha>"
   branch: "<branch-name>"
   what_was_done: "<description of implementation>"
   findings:
     - "<finding 1>"
   suggestions:
     - "<suggestion 1>"
   ```

You MUST:
- Only work on a single task per iteration
- Always use a feature branch for development
- Commit one logical change at a time to the feature branch
- Write .ralphish/summary.yaml before finishing
- NOT update progress.yaml — the orchestrator handles that'

    REVIEWER_PROMPT='You are the REVIEWER phase of a three-phase development loop (worker → reviewer → orchestrator).

## Instructions

1. Read `.ralphish/summary.yaml` to get the `task_id`, `base_sha`, `head_sha`, and `branch`.

2. Read `progress.yaml` to understand the task requirements (find the task matching `task_id`).

3. Examine the exact diff using: `git diff <base_sha>..<head_sha>`
   Use the SHAs from summary.yaml — do NOT diff branch names, as branches may include unrelated commits.

4. Review the implementation for:
   - **Correctness**: Does it match the task requirements?
   - **Quality**: Code style, error handling, edge cases
   - **Test coverage**: Are there adequate tests?
   - **Task alignment**: Does the work stay within scope?

5. Write `.ralphish/review.yaml` with this exact structure:
   ```yaml
   task_id: <integer>
   base_sha: "<40-char sha>"
   head_sha: "<40-char sha>"
   verdict: approve  # or: request_changes
   remarks:
     - "<specific remark — reference files and line numbers>"
   ```

You MUST:
- NOT modify any code, configuration, or project files
- NOT update progress.yaml
- Use the exact base_sha..head_sha range from summary.yaml for your diff
- Be specific in remarks — reference files and line numbers
- Only use `approve` or `request_changes` as the verdict'

    ORCHESTRATOR_PROMPT='You are the ORCHESTRATOR phase of a three-phase development loop (worker → reviewer → orchestrator).

Current iteration: {{ITERATION}}

## Instructions

1. Read `.ralphish/summary.yaml`, `.ralphish/review.yaml`, and `progress.yaml`.

2. Validate review identity:
   - `review.yaml.task_id` must match `summary.yaml.task_id`
   - `review.yaml.base_sha` must match `summary.yaml.base_sha`
   - `review.yaml.head_sha` must match `summary.yaml.head_sha`
   If they do not match, treat this as a review failure and skip to writing context.yaml with an error note.

3. Based on the verdict in review.yaml:

   **If `approve`:**
   - Set the task status to `done` in progress.yaml
   - Record `branch` and `head_sha` on the task
   - Set `retry_count` to 0 on the task

   **If `request_changes`:**
   - Increment `retry_count` on the task (add the field if missing, starting from 0)
   - Set `last_rejection` to a short summary of the rejection reason
   - If `retry_count >= 3`, you MUST escalate — do NOT retry again:
     - Preferred: split into smaller subtasks (new tasks with `parent_id` = original task ID, IDs from `next_id`, increment `next_id` after each)
     - Fallback: set task status to `blocked` with explanation in `last_rejection`
     - Last resort: set task status to `skipped` with explanation in `last_rejection`
   - Otherwise: keep task as `todo`

4. Ensure `progress.yaml` has an `orchestration` section (create it if missing). Append to `orchestration.history`:
   ```yaml
   - iteration: {{ITERATION}}
     task_id: <id>
     verdict: <approve|request_changes>
     summary: "<what happened>"
     decision: "<what you decided: done|retry|split|blocked|skipped>"
   ```

5. Write `.ralphish/context.yaml` for the next worker iteration:
   ```yaml
   assigned_task_id: <next eligible task ID, or current task ID if retrying>
   feedback: "<feedback for the worker>"
   reviewer_remarks:
     - "<remark from review.yaml>"
   prior_attempt_branch: "<branch from summary.yaml>"
   prior_attempt_head_sha: "<head_sha from summary.yaml>"
   ```

6. Determine the next action:
   - If NO remaining `todo` tasks (all are done/blocked/skipped): output `<promise>COMPLETE</promise>`
   - If external action is needed before next task (PR merge, deployment, manual approval, or you significantly restructured the plan): output `<promise>PAUSE</promise>`
   - Otherwise: output nothing (the loop continues to the next iteration)

You MUST:
- Only modify `progress.yaml` and files in `.ralphish/`
- NOT modify any code, source files, or project configuration
- Increment `next_id` when creating new subtasks
- Keep `orchestration.history` as an append-only log
- Use valid task statuses: `todo`, `done`, `blocked`, `skipped`'

    # ─── Helper functions ────────────────────────────────────────────────

    TMPFILE=$(mktemp)
    printf '\033[?25l'  # hide cursor
    cleanup() {
        trap - INT TERM
        printf '\033[?25h'  # restore cursor
        echo ""
        echo "Interrupted — aborting sandbox: $SANDBOX"
        pkill -P $$ 2>/dev/null || true
        docker sandbox stop "$SANDBOX" &>/dev/null &
        rm -f "$TMPFILE"
        exit 130
    }
    trap cleanup INT TERM
    trap 'printf "\033[?25h"; rm -f "$TMPFILE"' EXIT

    # Run a bash command inside the sandbox (for utility operations, no Claude)
    sandbox_exec() {
        docker sandbox exec "$SANDBOX" bash -c "cd '$WORKSPACE' && $1"
    }

    # Run a Claude phase in the sandbox and stream output through the formatter
    run_phase() {
        local phase="$1"
        local prompt="$2"

        sandbox "${PHASE_ARGS[@]}" --prompt "$prompt" "$WORKSPACE" | \
            tee "$TMPFILE" | \
            python3 -u "$SCRIPT_DIR/stream-claude-json.py" \
                --iteration "$i" --max "$MAX_ITERATIONS" \
                --sandbox "$SANDBOX" --workspace "$WORKSPACE" \
                --phase "$phase" &
        local pid=$!
        local rc=0
        wait "$pid" || rc=$?
        return $rc
    }

    # Fetch upstream and update the local base branch without switching away from current branch
    sync_phase() {
        docker sandbox exec "$SANDBOX" bash -c '
            cd "'"$WORKSPACE"'"
            git fetch origin 2>/dev/null || true
            DEFAULT_BRANCH=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed "s|refs/remotes/origin/||")
            [ -z "$DEFAULT_BRANCH" ] && DEFAULT_BRANCH="main"
            CURRENT=$(git branch --show-current 2>/dev/null)
            if [ "$CURRENT" = "$DEFAULT_BRANCH" ]; then
                git pull origin "$DEFAULT_BRANCH" 2>/dev/null || true
            else
                git fetch origin "$DEFAULT_BRANCH":"$DEFAULT_BRANCH" 2>/dev/null || true
            fi
        ' 2>/dev/null || true
    }

    # ─── Clean transient state ───────────────────────────────────────────

    sandbox_exec "rm -rf .ralphish && mkdir -p .ralphish" 2>/dev/null

    # ─── Main loop ───────────────────────────────────────────────────────

    for ((i=1; i<=MAX_ITERATIONS; i++)); do

        # Phase 0: Sync — fetch upstream, update base branch
        sync_phase

        # Phase 1: Worker — implement one task, write summary.yaml
        worker_prompt="${WORKER_PROMPT//\{\{ITERATION\}\}/$i}"
        if ! run_phase "worker" "$worker_prompt"; then
            echo "Worker phase failed"
            exit 1
        fi
        if ! sandbox_exec "test -f .ralphish/summary.yaml" 2>/dev/null; then
            echo "Worker phase did not produce .ralphish/summary.yaml"
            exit 1
        fi

        # Phase 2: Reviewer — review the diff, write review.yaml (retry once)
        reviewer_ok=false
        for attempt in 1 2; do
            if run_phase "reviewer" "$REVIEWER_PROMPT"; then
                if sandbox_exec "test -f .ralphish/review.yaml" 2>/dev/null; then
                    reviewer_ok=true
                    break
                fi
            fi
            [ "$attempt" -eq 1 ] && echo "Reviewer phase failed, retrying..."
        done
        if [ "$reviewer_ok" = false ]; then
            echo "Reviewer phase failed after retry"
            exit 1
        fi

        # Phase 3: Orchestrator — update progress.yaml, write context.yaml
        orch_prompt="${ORCHESTRATOR_PROMPT//\{\{ITERATION\}\}/$i}"
        orch_rc=0
        run_phase "orchestrator" "$orch_prompt" || orch_rc=$?

        # Check signals from orchestrator output
        if grep -q '<promise>COMPLETE</promise>' "$TMPFILE"; then
            echo "All tasks complete after $i iterations."
            exit 0
        fi
        if grep -q '<promise>PAUSE</promise>' "$TMPFILE"; then
            echo "Paused — external action needed. Run ralphish again to resume."
            exit 0
        fi

        if [ "$orch_rc" -ne 0 ]; then
            echo "Orchestrator phase failed (exit code $orch_rc)"
            exit "$orch_rc"
        fi
    done

    echo "Reached max iteration count ($MAX_ITERATIONS)"
    ;;
esac
