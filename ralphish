#!/bin/bash
set -e
set -o pipefail

MODE="claude"
WORKSPACE=""
NEW=false
MAX_ITERATIONS=1
INCLUDE_LOCAL_CONFIG=false
CUSTOM_ENV=()
ENV_FILE=""

while [[ $# -gt 0 ]]; do
    case $1 in
    --help)
        usage
        exit 0
        ;;
    --new)
        NEW=true
        shift
        ;;
    --rm)
        MODE="rm"
        shift
        ;;
    --max-iterations)
        shift
        if [ -z "$1" ]; then
          echo "Usage: --max-iterations <iterations>"
          exit 1
        fi
        MAX_ITERATIONS="$1"
        shift
        ;;
    --env=*)
        CUSTOM_ENV+=("${1#--env=}")
        shift
        ;;
    --env)
        if [ -z "$2" ]; then
            echo "Error: --env requires a KEY=VALUE argument"
            exit 1
        fi
        CUSTOM_ENV+=("$2")
        shift 2
        ;;
    --env-file=*)
        ENV_FILE="${1#--env-file=}"
        shift
        ;;
    --env-file)
        if [ -z "$2" ]; then
            echo "Error: --env-file requires a file path argument"
            exit 1
        fi
        ENV_FILE="$2"
        shift 2
        ;;
    --include-local-config)
        INCLUDE_LOCAL_CONFIG=true
        shift
        ;;
    *)
        WORKSPACE="$1"
        shift
        ;;
    esac
done

if [ -z "$WORKSPACE" ]; then
    WORKSPACE="."
fi

if [ -z "$CC_TOKEN" ] && [ "$MODE" != "rm" ]; then
    echo "Error: CC_TOKEN environment variable is not set"
    exit 1
fi

WORKSPACE="$(cd "$WORKSPACE" && pwd)"
BASENAME="$(basename "$WORKSPACE")"

# Truncate sandbox name to avoid Unix socket path length limits
# Docker uses: ~/.docker/sandboxes/vm/<name>/eth (max ~94 chars total)
MAX_NAME_LEN=40
if [ ${#BASENAME} -gt $MAX_NAME_LEN ]; then
    HASH=$(echo -n "$BASENAME" | shasum | cut -c1-6)
    BASENAME="${BASENAME:0:$((MAX_NAME_LEN - 7))}-$HASH"
fi
SANDBOX="claude-$BASENAME"

case "$MODE" in
rm)
    sandbox --rm "$WORKSPACE"
    ;;
*)
    # Build sandbox args to pass through for lifecycle management
    SANDBOX_ARGS=()
    [ "$NEW" = true ] && SANDBOX_ARGS+=(--new)
    [ "$INCLUDE_LOCAL_CONFIG" = true ] && SANDBOX_ARGS+=(--include-local-config)
    for env_var in "${CUSTOM_ENV[@]}"; do SANDBOX_ARGS+=(--env "$env_var"); done
    [ -n "$ENV_FILE" ] && SANDBOX_ARGS+=(--env-file "$ENV_FILE")

    # Use sandbox to create/resume (and handle --new, --include-local-config, env)
    # bash exits immediately when stdin closes; 2>/dev/null suppresses TTY warnings
    sandbox "${SANDBOX_ARGS[@]}" --bash "$WORKSPACE" <<< 'exit 0' 2>/dev/null || true

    CLAUDE_PROMPT='
        1. Find the highest priority task from progress.yaml
        2. Implement the task
        3. Run all tests/checks for the project and fix any problems
        4. Append your progress to progress.yaml
        5. If all tasks are complete, output <promise>COMPLETE</promise>

        You MUST:
        - Only work on a single task
        - Always use a feature branch for development, create it if the branch does not exist
        - A feature branch can be based on the projects default branch or another feature branch
        - Commit one change at a time to the feature branch
    '

    TMPFILE=$(mktemp)
    printf '\033[?25l'  # hide cursor
    cleanup() {
        trap - INT TERM
        printf '\033[?25h'  # restore cursor
        echo ""
        echo "Interrupted — aborting sandbox: $SANDBOX"
        pkill -P $$ 2>/dev/null || true
        docker sandbox stop "$SANDBOX" &>/dev/null &
        rm -f "$TMPFILE"
        exit 130
    }
    trap cleanup INT TERM
    trap 'printf "\033[?25h"; rm -f "$TMPFILE"' EXIT
    for ((i=1; i<=MAX_ITERATIONS; i++)); do
        sandbox "${SANDBOX_ARGS[@]}" --prompt "$CLAUDE_PROMPT" "$WORKSPACE" | tee "$TMPFILE" | python3 -u "$(dirname "$0")/stream-claude-json.py" --iteration "$i" --max "$MAX_ITERATIONS" --sandbox "$SANDBOX" --workspace "$WORKSPACE" &
        pid=$!

        rc=0
        wait "$pid" || rc=$?
        if [ $rc -ne 0 ] && ! grep -q '<promise>COMPLETE</promise>' "$TMPFILE"; then
            echo "Sandbox exec failed (exit code $rc)"
            exit $rc
        fi

      if grep -q '<promise>COMPLETE</promise>' "$TMPFILE"; then
        echo "PRD complete after $i iterations."
        exit 0
      fi
    done
    echo "Reached max iteration count"
    ;;
esac
